# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # Set to "production" when deploying

# Public URL of the server (used as the base for download links).
# In production: HOST_URL=https://yourdomain.com
# In development: leave commented out — defaults to http://localhost:3000
# HOST_URL=https://yourdomain.com

# Comma-separated list of allowed CORS origins (production only).
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# In development: leave commented out — localhost origins are allowed by default
# ALLOWED_ORIGINS=https://yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── AI / Embeddings ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── WhatsApp / Baileys ────────────────────────────────────────────────────────
# Controls Baileys verbosity. Options: silent | error | warn | info | debug
BAILEYS_LOG_LEVEL=silent

# ── Google Drive (legacy — not required with local file storage) ───────────────
# GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
